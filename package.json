{
  "name": "liftosaur",
  "version": "1.0.0",
  "description": "App for tracking weight lifting progress",
  "main": "index.js",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "npm run ensure:localdomain && npm run build:prepare",
    "build:prepare": "npm run ensure:localdomain && npm run build:theme && npm run build:markdown && npm run build:programs && npm run build:exercises && npm run plannerhighlighter && npm run blog && npm run docs && npm run sitemap && NODE_ENV=production npm run build:dev",
    "ensure:localdomain": "test -f localdomain.js || cp localdomain.default.js localdomain.js",
    "build:markdown": "node scripts/build-markdown.js",
    "build:programs": "TS_NODE_TRANSPILE_ONLY=1 ts-node scripts/build-programs.ts",
    "build:exercises": "TS_NODE_TRANSPILE_ONLY=1 ts-node scripts/build-exercises.ts",
    "build:theme": "node scripts/generate-theme-css.js",
    "build:semantic": "node generate-semantic-colors.js",
    "docs": "generate-md --layout ./src/docs/layout/ --input ./src/docs/content/ --output ./docs",
    "plannerhighlighter": "tsc --skipLibCheck --outDir dist-plannerhighlighter ./src/pages/planner/plannerHighlighter.ts",
    "blog": "eleventy",
    "build:dev": "webpack",
    "sitemap": "TS_NODE_TRANSPILE_ONLY=1 ts-node ./src/sitemap.ts"
  },
  "author": "Anton Astashov",
  "license": "AGPL-3.0",
